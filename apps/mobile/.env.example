# Expo public env — inlined into the client bundle. NEVER put secrets here.
# Copy to apps/mobile/.env.local for local development.
#
# EXPO_PUBLIC_API_URL=http://localhost:8787
#
# Privy (from the Privy dashboard — human task YK-455). Without these the app
# boots but auth is disabled; with them, a dev build runs real Privy auth.
# EXPO_PUBLIC_PRIVY_APP_ID=
# EXPO_PUBLIC_PRIVY_CLIENT_ID=
