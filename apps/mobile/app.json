{
  "expo": {
    "name": "Sava",
    "slug": "sava",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sava",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.getsava.mobile"
    },
    "android": {
      "package": "app.getsava.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization",
      "expo-font",
      "./plugins/withExpoSwift5.js",
      "@sentry/react-native"
    ]
  }
}
