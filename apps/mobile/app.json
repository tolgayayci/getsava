{
  "expo": {
    "name": "Sava",
    "slug": "sava",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sava",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.getsava.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.getsava.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization",
      "expo-font",
      "./plugins/withExpoSwift5.js"
    ],
    "extra": {
      "eas": {
        "projectId": "39a9b2cd-b07a-4a91-ab86-0a1ce0045089"
      }
    },
    "owner": "tolga0x",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/39a9b2cd-b07a-4a91-ab86-0a1ce0045089"
    }
  }
}
