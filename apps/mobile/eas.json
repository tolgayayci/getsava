{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_STELLAR_NETWORK": "testnet",
        "EXPO_PUBLIC_PRIVY_APP_ID": "cmptsx19j00ba0cjv8nghcdhr"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_STELLAR_NETWORK": "testnet",
        "EXPO_PUBLIC_PRIVY_APP_ID": "cmptsx19j00ba0cjv8nghcdhr"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_STELLAR_NETWORK": "testnet",
        "EXPO_PUBLIC_PRIVY_APP_ID": "cmptsx19j00ba0cjv8nghcdhr"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
